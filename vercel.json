{
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/(.*)",         "destination": "/index.html"   }
  ],
  "headers": [
    {
      "source": "/SKILL.md",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    }
  ]
}
